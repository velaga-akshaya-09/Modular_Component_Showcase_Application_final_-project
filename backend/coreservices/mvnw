#!/bin/sh
set -e
MAVEN_VERSION=3.9.9
PROJECT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
MAVEN_HOME="$PROJECT_DIR/.mvn/apache-maven-$MAVEN_VERSION"
MAVEN_ZIP="$PROJECT_DIR/.mvn/apache-maven-$MAVEN_VERSION-bin.zip"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.zip"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  mkdir -p "$PROJECT_DIR/.mvn"
  if [ ! -f "$MAVEN_ZIP" ]; then
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$MAVEN_URL" -o "$MAVEN_ZIP"
    else
      wget -O "$MAVEN_ZIP" "$MAVEN_URL"
    fi
  fi
  unzip -oq "$MAVEN_ZIP" -d "$PROJECT_DIR/.mvn"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"